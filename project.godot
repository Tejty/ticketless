; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[accessibility]

general/accessibility_support=2

[application]

config/name="Ticketless"
config/description="You play as a homeless person in the subway, begging people for money to survive, and buy a ticket.

You can move around with W, A, S, D, or arrows and interact with things with E

Drive between stations via the train, and beg for money to buy food (and alcohol), and survive.
Your goal is to buy a ticket to become a normal person.
How many beers can you drink in the process?"
config/version="0.2b"
run/main_scene="uid://boh1sym2spdtq"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
boot_splash/show_image=false
boot_splash/use_filter=false
config/icon="uid://d0ee3uem7nh4o"

[autoload]

InteractableList="*uid://dxhfjvfjgxrn8"
MusicPLayer="*uid://bt2hi62kp63yp"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
mouse_cursor/custom_image="uid://csfktqq1dvtem"

[gui]

theme/default_font_antialiasing=0
theme/custom_font="uid://cj80woymlv6v2"
